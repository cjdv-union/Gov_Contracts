# ── Required ──────────────────────────────────────────────────────────────────

# Harmonic API key — found at https://console.harmonic.ai/dashboard/settings/api
HARMONIC_API_KEY=your_harmonic_api_key_here

# Slack Bot OAuth token — starts with xoxb-
# Create a Slack app at https://api.slack.com/apps, add chat:write scope, install to workspace
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack channel to post alerts to (include the # prefix)
SLACK_CHANNEL=#deal-alerts

# ── Optional filters ──────────────────────────────────────────────────────────

# Minimum round size in $M (leave blank for no minimum)
MIN_ROUND_SIZE_M=

# Maximum round size in $M (leave blank for no maximum)
MAX_ROUND_SIZE_M=

# Minimum employee count (leave blank for no minimum)
MIN_EMPLOYEES=
